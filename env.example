# ─────────────────────────────────────────────────────────
# .env.example  –  copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# How long (seconds) to cache data from AMFI / mfapi.in before refreshing
CACHE_TTL_SECONDS=3600

# Maximum number of funds a user can compare in one session
MAX_FUNDS_COMPARE=10

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15
